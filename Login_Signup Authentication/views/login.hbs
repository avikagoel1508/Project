<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">

    <div class="card">

        <h1>Welcome Back 👋</h1>
        <p class="subtitle">Login to continue</p>

        <form action="/login" method="POST">

            <input
                type="text"
                name="username"
                placeholder="Username"
                required>

            <input
                type="password"
                name="password"
                placeholder="Password"
                required>

            <button type="submit">
                Login
            </button>

        </form>

        <p class="bottom-text">
            Don't have an account?
            <a href="/signup">Sign Up</a>
        </p>

    </div>

</div>

</body>
</html>